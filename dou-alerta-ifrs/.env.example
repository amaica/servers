# Use .env.local para credenciais (tem prioridade sobre .env e não vai pro git)

# SMTP (Gmail: use senha de app em https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=synki.sistemas@gmail.com
SMTP_PASS=ezipnyqzeihirdad
SMTP_USE_TLS=true
FROM_EMAIL=synki.sistemas@gmail.com
TO_EMAIL=aureliomaica@gmail.com

# Filtros
SCORE_THRESHOLD=5.0
KEYWORDS_EXTRA=palavra1,palavra2

# DOU - Feed RSS Imprensa Nacional (in.gov.br/dou2 retorna 404)
# Múltiplos: separar por ; ou ,
DOU_RSS_URLS=https://www.gov.br/imprensanacional/pt-br/RSS

# Storage
DB_PATH=dou_alerta.db

# E-mail
EMAIL_MAX_ITEMS=20
# DRY_RUN=true  # não envia e-mail (apenas simula)
